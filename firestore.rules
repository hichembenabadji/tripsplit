rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function tripExists(tripId) {
      return exists(/databases/$(database)/documents/trips/$(tripId));
    }

    function tripParticipantIds(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds;
    }

    function isExistingTripParticipant() {
      return signedIn() && request.auth.uid in resource.data.participantIds;
    }

    function isParentTripParticipant(tripId) {
      return signedIn() &&
          tripExists(tripId) &&
          request.auth.uid in tripParticipantIds(tripId);
    }

    function isParentTripCreator(tripId) {
      return signedIn() &&
          tripExists(tripId) &&
          request.auth.uid ==
              get(/databases/$(database)/documents/trips/$(tripId)).data.createdBy;
    }

    function validTripStatus(status) {
      return status is string &&
          status in ['inProgress', 'upcoming', 'settled'];
    }

    function validExpenseSplitType(splitType) {
      return splitType is string &&
          splitType in ['equally', 'custom', 'percent', 'fixed'];
    }

    function validUserDocument() {
      return request.resource.data.keys().hasAll([
            'email',
            'displayName',
            'createdAt',
          ]) &&
          request.resource.data.keys().hasOnly([
            'email',
            'displayName',
            'createdAt',
          ]) &&
          request.resource.data.email is string &&
          request.resource.data.email.size() > 0 &&
          request.resource.data.displayName is string &&
          request.resource.data.createdAt is timestamp;
    }

    function validTripCreate() {
      return request.resource.data.keys().hasAll([
            'name',
            'destination',
            'currencyCode',
            'currencySymbol',
            'createdBy',
            'participantIds',
            'status',
            'createdAt',
          ]) &&
          request.resource.data.keys().hasOnly([
            'name',
            'destination',
            'startDate',
            'endDate',
            'currencyCode',
            'currencySymbol',
            'createdBy',
            'participantIds',
            'status',
            'createdAt',
          ]) &&
          request.resource.data.name is string &&
          request.resource.data.name.size() > 0 &&
          request.resource.data.destination is string &&
          request.resource.data.destination.size() > 0 &&
          request.resource.data.currencyCode is string &&
          request.resource.data.currencyCode.size() > 0 &&
          request.resource.data.currencySymbol is string &&
          request.resource.data.currencySymbol.size() > 0 &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.participantIds is list &&
          request.resource.data.participantIds.size() > 0 &&
          request.auth.uid in request.resource.data.participantIds &&
          validTripStatus(request.resource.data.status) &&
          request.resource.data.createdAt is timestamp;
    }

    function validTripUpdate() {
      return request.resource.data.keys().hasAll([
            'name',
            'destination',
            'currencyCode',
            'currencySymbol',
            'createdBy',
            'participantIds',
            'status',
            'createdAt',
          ]) &&
          request.resource.data.keys().hasOnly([
            'name',
            'destination',
            'startDate',
            'endDate',
            'currencyCode',
            'currencySymbol',
            'createdBy',
            'participantIds',
            'status',
            'createdAt',
          ]) &&
          request.resource.data.name is string &&
          request.resource.data.name.size() > 0 &&
          request.resource.data.destination is string &&
          request.resource.data.destination.size() > 0 &&
          request.resource.data.currencyCode is string &&
          request.resource.data.currencyCode.size() > 0 &&
          request.resource.data.currencySymbol is string &&
          request.resource.data.currencySymbol.size() > 0 &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.participantIds is list &&
          request.resource.data.participantIds.size() > 0 &&
          request.resource.data.participantIds.hasAll(resource.data.participantIds) &&
          request.resource.data.createdBy in request.resource.data.participantIds &&
          validTripStatus(request.resource.data.status);
    }

    function validExpenseWrite(tripId) {
      return request.resource.data.keys().hasAll([
            'title',
            'amount',
            'paidBy',
            'splitType',
            'beneficiaryIds',
            'createdAt',
          ]) &&
          request.resource.data.keys().hasOnly([
            'title',
            'amount',
            'paidBy',
            'splitType',
            'beneficiaryIds',
            'createdAt',
          ]) &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0 &&
          request.resource.data.paidBy is string &&
          request.resource.data.paidBy in tripParticipantIds(tripId) &&
          request.resource.data.beneficiaryIds is list &&
          request.resource.data.beneficiaryIds.hasOnly(tripParticipantIds(tripId)) &&
          validExpenseSplitType(request.resource.data.splitType) &&
          request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if signedIn() && request.auth.uid == userId;

      // Firestore rules can validate list/query shape (for example `limit`)
      // but cannot directly inspect arbitrary `where("email", "==", ...)`
      // filters. This keeps the lookup surface small for addParticipantByEmail,
      // but it is not a perfect "email-only" guarantee.
      allow list: if signedIn() && request.query.limit == 1;

      allow create, update: if signedIn() &&
          request.auth.uid == userId &&
          validUserDocument();

      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /trips/{tripId} {
      allow get, list: if isExistingTripParticipant();

      allow create: if signedIn() && validTripCreate();

      allow update: if isExistingTripParticipant() && validTripUpdate();

      allow delete: if signedIn() && request.auth.uid == resource.data.createdBy;

      match /expenses/{expenseId} {
        allow get, list: if isParentTripParticipant(tripId);

        allow create: if isParentTripParticipant(tripId) &&
            validExpenseWrite(tripId);

        allow update: if isParentTripParticipant(tripId) &&
            validExpenseWrite(tripId) &&
            request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isParentTripCreator(tripId);
      }
    }
  }
}
